APP_NAME=GST API Engine
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/gst_engine
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=change-this-postgres-password

JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_SECRET=change-this-only-if-using-hs256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=15

ALLOWED_ORIGINS=["https://app.yourdomain.com","https://admin.yourdomain.com"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Email / OTP delivery
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@example.com
SMTP_PASSWORD=change-this-smtp-password
FROM_EMAIL=support@example.com
FROM_NAME=ApexBooks

S3_ENDPOINT=http://minio:9000
S3_BUCKET=gst-api-engine
S3_ACCESS_KEY=change-this-minio-access-key
S3_SECRET_KEY=change-this-minio-secret-key
MINIO_ROOT_USER=change-this-minio-root-user
MINIO_ROOT_PASSWORD=change-this-minio-root-password
