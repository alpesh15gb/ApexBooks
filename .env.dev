# ========================
# GST API Engine - LOCAL DEV Environment
# ========================

APP_NAME=GST API Engine
ENVIRONMENT=development
DATABASE_URL=sqlite+pysqlite:///./dev.db
REDIS_URL=redis://redis:6379/0

JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_SECRET=dev-only-secret-key-change-in-production-2026

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=15

ALLOWED_ORIGINS=["http://localhost:8080","http://localhost:3000","http://127.0.0.1:8080"]

RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60
